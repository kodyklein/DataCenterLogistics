{
  "privileges": [
    { "name": "ExportContent", "essential": false },
    { "name": "LocalStorage", "essential": false }
  ],

  "dataRoles": [
    {
      "displayName": "Inputs (Measures)",
      "name": "measure",
      "kind": "Measure"
    }
  ],

  "dataViewMappings": [
    {
      "categorical": {
        "values": {
          "bind": { "to": "measure" }
        }
      }
    }
  ],

  "objects": {
    "building": {
      "displayName": "Building",
      "properties": {
        "fillColor": {
          "displayName": "Building Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "outlineColor": {
          "displayName": "Outline Color",
          "type": { "fill": { "solid": { "color": true } } }
        },
        "outlineWidth": {
          "displayName": "Outline Width",
          "type": { "numeric": true }
        },
        "showLabels": {
          "displayName": "Show Labels",
          "type": { "bool": true }
        },

        "renderMode": {
          "displayName": "Render Mode",
          "type": {
            "enumeration": [
              { "value": "isometric", "displayName": "Isometric (Recommended)" },
              { "value": "stack", "displayName": "Footprint + Stack" }
            ]
          }
        },

        "mechEvery": {
          "displayName": "Mechanical Floor Every N Stories",
          "type": { "numeric": true }
        },

        "showLandscaping": {
          "displayName": "Show Landscaping",
          "type": { "bool": true }
        },

        "windowDensity": {
          "displayName": "Window Density",
          "type": { "numeric": true }
        }
      }
    }
  },

  "supportsHighlight": false
}